# Copy to .env and adjust. .env is gitignored.
# Postgres / pgvector
MDHPP_PG_HOST=localhost
MDHPP_PG_PORT=5432
MDHPP_PG_DB=mdhpp
MDHPP_PG_USER=mdhpp
MDHPP_PG_PASSWORD=mdhpp

# Models (local BGE by default; no paid API required)
MDHPP_EMBEDDING_MODEL=BAAI/bge-m3
MDHPP_EMBEDDING_DIM=1024
MDHPP_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Retrieval
MDHPP_RETRIEVE_TOP_K=20
MDHPP_RERANK_TOP_K=5
MDHPP_RELEVANCE_FLOOR=0.02

# Generation (ollama local by default)
MDHPP_LLM_PROVIDER=ollama
MDHPP_LLM_MODEL=llama3.2:3b
MDHPP_LLM_TEMPERATURE=0.1
